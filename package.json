  "description": "Media processing toolkit powered by FFmpeg — audio normalization, video conversion, format tools, and more",
  "main": "./out/main/index.js",
  "author": "molex",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
