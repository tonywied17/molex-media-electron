{
  "name": "molex-media",
  "version": "4.3.0",
  "description": "Media processing toolkit powered by FFmpeg - audio normalization, video conversion, format tools, and more",
  "main": "./out/main/index.js",
  "author": "molex",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "package": "electron-vite build && electron-builder --publish never",
    "package:win": "electron-vite build && electron-builder --win --publish never",
    "package:mac": "electron-vite build && electron-builder --mac --publish never",
    "package:linux": "electron-vite build && electron-builder --linux --publish never",
    "release": "electron-vite build && electron-builder --publish always",
    "release:win": "electron-vite build && electron-builder --win --publish always"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "extract-zip": "^2.0.1",
    "tar": "^7.4.0",
    "youtube-dl-exec": "^3.1.4"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.19",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "framer-motion": "^12.38.0",
    "jsdom": "^29.0.1",
    "lucide-react": "^1.7.0",
    "postcss": "^8.4.38",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "zustand": "^5.0.12"
  }
}
