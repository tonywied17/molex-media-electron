{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx"
  ],
  "exclude": ["out", "dist", "node_modules"],
  "compilerOptions": {
    "composite": true,
    "outDir": "./out",
    "jsx": "react-jsx",
    "paths": {
      "@renderer/*": ["./src/renderer/src/*"]
    }
  }
}
